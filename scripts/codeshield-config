#!/usr/bin/env bash
# CODE SHIELD V3.1.12 -- Configuration Management CLI
# Usage: codeshield-config <command> [args]
#
# Commands:
#   show                     Show current configuration (secrets masked)
#   edit                     Interactive edit of all secrets
#   set KEY=VALUE            Set a single configuration key
#   add-channel              Interactive: add a messaging channel (WeCom/Feishu/Discord/Custom)
#   add-model [provider]     Add an LLM provider (openai|anthropic|deepseek|glm5|kimi|minimax|custom)
#   patch-provider <provider> Patch openclaw JS files for a non-native provider (deepseek|glm5)
#   list-channels            List configured channels
#   list-models              List configured LLM providers
#   proxy-allow <domain>     Add a domain to the Squid proxy whitelist
#   network-mode [open|strict] Show or toggle network access mode
#   qmd-backend [enable|show|disable] Manage the OpenClaw QMD backend under Codeshield
#   help                     Show this help message
set -euo pipefail
export LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8 2>/dev/null || export LC_ALL=C.UTF-8 LANG=C.UTF-8 2>/dev/null || true

###############################################################################
# Constants
###############################################################################
readonly CS_CONF_DIR="/etc/openclaw-codeshield"
readonly SECRETS_FILE="$CS_CONF_DIR/secrets.env"
readonly SECRETS_ENC="$CS_CONF_DIR/secrets.env.enc"
readonly WHITELIST_FILE="$CS_CONF_DIR/proxy-whitelist.conf"
readonly CHANNELS_DIR="$CS_CONF_DIR/channels.d"
readonly MODELS_DIR="$CS_CONF_DIR/models.d"
readonly SQUID_CONF="/etc/squid/squid.conf"
readonly OPENCLAW_MODULE_DIR="/home/openclaw/.npm-global/lib/node_modules/openclaw"

###############################################################################
# Provider patch data: providers NOT natively supported by openclaw that need
# JS file patching when added via add-model.
#
# Format per entry:  ENV_VAR|BASE_URL|API_TYPE|MODEL_IDS|MODEL_NAMES|REASONING_FLAGS
#   MODEL_IDS, MODEL_NAMES, REASONING_FLAGS: comma-separated, in sync order
#
# OPENCLAW_MODEL_REFS: space-separated list of "provider/model-id" strings to
#   whitelist in openclaw.json agents.defaults.models
###############################################################################
declare -A OPENCLAW_JS_PATCH_PROVIDERS=(
    [deepseek]="DEEPSEEK_API_KEY|https://api.deepseek.com/v1|openai-completions|deepseek-chat,deepseek-reasoner|DeepSeek V3,DeepSeek R1|false,true"
    [glm5]="GLM_API_KEY|https://open.bigmodel.cn/api/paas/v4|openai-completions|glm-4-flash,glm-4-air|GLM-4-Flash,GLM-4-Air|false,false"
)
declare -A OPENCLAW_MODEL_REFS=(
    [deepseek]="deepseek/deepseek-chat deepseek/deepseek-reasoner"
    [glm5]="glm5/glm-4-flash glm5/glm-4-air"
    [anthropic]="anthropic/claude-opus-4-6 anthropic/claude-sonnet-4-6"
)

###############################################################################
# Color helpers
###############################################################################
if [ -t 1 ] 2>/dev/null; then
    RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
    CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; RESET=''
fi
info()  { printf "${CYAN}[INFO]${RESET}  %s\n" "$*"; }
ok()    { printf "${GREEN}[OK]${RESET}    %s\n" "$*"; }
warn()  { printf "${YELLOW}[WARN]${RESET}  %s\n" "$*"; }
fail()  { printf "${RED}[FAIL]${RESET}  %s\n" "$*"; }

###############################################################################
# Privilege check
###############################################################################
require_root() {
    if [ "$(id -u)" -ne 0 ]; then
        fail "This command must be run as root (sudo codeshield-config $*)."
        exit 1
    fi
}

###############################################################################
# Secrets file management: decrypt -> edit -> re-encrypt
###############################################################################
ensure_dirs() {
    mkdir -p "$CS_CONF_DIR" "$CHANNELS_DIR" "$MODELS_DIR"
}

# Decrypt secrets to plaintext (if encrypted)
decrypt_secrets() {
    if [ -f "$SECRETS_ENC" ] && command -v systemd-creds &>/dev/null; then
        if [ ! -f "$SECRETS_FILE" ]; then
            info "Decrypting secrets ..."
            systemd-creds decrypt "$SECRETS_ENC" "$SECRETS_FILE" 2>/dev/null || {
                # Try the unseal script as fallback
                if [ -x /usr/local/sbin/codeshield-secrets-unseal ]; then
                    /usr/local/sbin/codeshield-secrets-unseal
                    # Copy from tmpfs runtime location
                    if [ -f /run/openclaw-codeshield/secrets.env ]; then
                        cp /run/openclaw-codeshield/secrets.env "$SECRETS_FILE"
                    fi
                fi
            }
        fi
    fi
    if [ ! -f "$SECRETS_FILE" ]; then
        warn "No secrets file found. Creating empty one."
        printf "# Managed by CODE SHIELD. Keep mode 0600.\n" > "$SECRETS_FILE"
        chmod 0600 "$SECRETS_FILE"
    fi
}

# Re-encrypt and clean up plaintext
reencrypt_secrets() {
    if command -v systemd-creds &>/dev/null && [ -f /var/lib/systemd/credential.secret ]; then
        info "Re-encrypting secrets at rest ..."
        if [ -x /usr/local/sbin/codeshield-secrets-seal ]; then
            /usr/local/sbin/codeshield-secrets-seal --from "$SECRETS_FILE"
            ok "Secrets re-encrypted."
        else
            warn "codeshield-secrets-seal not found. Secrets remain plaintext."
        fi
    fi
}

restart_codeshield_secrets() {
    if systemctl list-unit-files codeshield-secrets.service >/dev/null 2>&1; then
        info "Refreshing codeshield-secrets.service runtime env ..."
        systemctl restart codeshield-secrets.service 2>/dev/null || true
        ok "codeshield-secrets.service refreshed."
    fi
}

# Read a key from secrets file
read_secret() {
    local key="$1"
    if [ -f "$SECRETS_FILE" ]; then
        grep -E "^${key}=" "$SECRETS_FILE" 2>/dev/null | head -1 | cut -d'=' -f2- || true
    fi
}

# Set a key in secrets file (add or replace)
write_secret() {
    local key="$1" value="$2"
    if grep -qE "^${key}=" "$SECRETS_FILE" 2>/dev/null; then
        # Replace existing -- use a temp file for safety with special chars
        local tmpf
        tmpf=$(mktemp)
        while IFS= read -r line; do
            if [[ "$line" == "${key}="* ]]; then
                printf '%s=%s\n' "$key" "$value"
            else
                printf '%s\n' "$line"
            fi
        done < "$SECRETS_FILE" > "$tmpf"
        mv "$tmpf" "$SECRETS_FILE"
    else
        printf '%s=%s\n' "$key" "$value" >> "$SECRETS_FILE"
    fi
    chmod 0600 "$SECRETS_FILE"
}

# Mask a secret for display (show first 4 and last 4 chars)
mask_secret() {
    local val="$1"
    local len=${#val}
    if [ "$len" -le 8 ]; then
        printf '%s' "****"
    else
        printf '%s...%s' "${val:0:4}" "${val: -4}"
    fi
}

###############################################################################
# Squid whitelist management
###############################################################################
ensure_whitelist() {
    if [ ! -f "$WHITELIST_FILE" ]; then
        printf "# CODE SHIELD -- Additional proxy whitelist domains\n" > "$WHITELIST_FILE"
        printf "# Added by codeshield-config. One domain per line.\n" >> "$WHITELIST_FILE"
        chmod 0644 "$WHITELIST_FILE"
    fi
}

add_to_whitelist() {
    local domain="$1"
    ensure_whitelist
    if ! grep -qxF "$domain" "$WHITELIST_FILE" 2>/dev/null; then
        printf '%s\n' "$domain" >> "$WHITELIST_FILE"
        ok "Added $domain to proxy whitelist."
    else
        info "$domain already in whitelist."
    fi
}

reload_squid() {
    if systemctl is-active squid &>/dev/null; then
        systemctl reload squid 2>/dev/null || systemctl restart squid 2>/dev/null || true
        ok "Squid proxy reloaded."
    fi
}

###############################################################################
# Restart openclaw service
###############################################################################
restart_openclaw() {
    if systemctl is-active openclaw &>/dev/null; then
        info "Restarting openclaw service ..."
        systemctl restart openclaw 2>/dev/null || true
        ok "openclaw service restarted."
    fi
}

find_openclaw_bin() {
    local candidate
    for candidate in \
        /home/openclaw/.npm-global/bin/openclaw \
        /usr/local/bin/openclaw \
        /usr/bin/openclaw; do
        if [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

print_openai_oauth_next_steps() {
    local openclaw_bin="${1:-/home/openclaw/.npm-global/bin/openclaw}"
    cat <<EOF

${BOLD}OpenAI OAuth is managed by OpenClaw's native login flow.${RESET}
${BOLD}OpenAI OAuth 由 OpenClaw 原生登录流程接管。${RESET}

No client id or client secret was stored in CODE SHIELD secrets.
本次不会把 client id 或 client secret 写入 CODE SHIELD secrets。

Run the following command in the server terminal to complete OAuth:
请在服务器终端运行下面这条命令完成 OAuth：

  sudo -u openclaw-svc env HOME=/var/lib/openclaw-svc XDG_CONFIG_HOME=/var/lib/openclaw-svc/.config $openclaw_bin onboard --auth-choice openai-codex

If OpenClaw prints a browser link, open it in your browser, finish login,
and paste the callback/result URL back into the terminal when prompted.
如果 OpenClaw 输出浏览器认证链接，请在浏览器中完成登录，并把回调结果链接粘贴回终端。

Recommended follow-up checks:
推荐后续检查：

  sudo -u openclaw-svc env HOME=/var/lib/openclaw-svc XDG_CONFIG_HOME=/var/lib/openclaw-svc/.config $openclaw_bin status
  sudo systemctl restart openclaw
EOF
}

###############################################################################
# Clear openclaw runtime caches (compile cache + JITI) so JS edits take effect
###############################################################################
clear_openclaw_caches() {
    local found=0
    while IFS= read -r cdir; do
        [ -d "$cdir" ] || continue
        rm -rf "$cdir" 2>/dev/null || true
        info "Cleared compile cache: $cdir"
        found=1
    done < <(find /tmp -maxdepth 5 -type d -name "node-compile-cache" 2>/dev/null || true)
    while IFS= read -r jdir; do
        [ -d "$jdir" ] || continue
        rm -rf "$jdir" 2>/dev/null || true
        info "Cleared JITI cache: $jdir"
        found=1
    done < <(find /tmp -maxdepth 5 -type d -name "jiti" 2>/dev/null || true)
    [ "$found" -eq 0 ] && info "No openclaw runtime caches found (already clean)."
    return 0
}

###############################################################################
# Patch openclaw dist JS files to register a non-native LLM provider.
# Called automatically by cmd_add_model for providers in OPENCLAW_JS_PATCH_PROVIDERS.
###############################################################################
patch_openclaw_provider() {
    local provider="$1"

    # Check if patching data exists for this provider
    local patch_data="${OPENCLAW_JS_PATCH_PROVIDERS[$provider]:-}"
    if [ -z "$patch_data" ]; then
        return 0  # native provider — no JS patching needed
    fi

    if ! command -v python3 &>/dev/null; then
        warn "python3 not found. Skipping openclaw JS patching for '$provider'."
        warn "Install python3 then run: codeshield-config patch-provider $provider"
        return 0
    fi

    IFS='|' read -r env_var base_url api_type model_ids model_names reasoning_flags <<< "$patch_data"

    info "Patching openclaw JS files for provider '$provider' ..."

    python3 - "$provider" "$env_var" "$base_url" "$api_type" \
        "$model_ids" "$model_names" "$reasoning_flags" "$OPENCLAW_MODULE_DIR" << 'PYEOF'
import sys, os

provider     = sys.argv[1]
env_var      = sys.argv[2]
base_url     = sys.argv[3]
api_type     = sys.argv[4]
model_ids    = sys.argv[5].split(',')
model_names  = sys.argv[6].split(',')
reasoning    = [r.strip() == 'true' for r in sys.argv[7].split(',')]
module_dir   = sys.argv[8]

# Derive JS identifiers from provider name
# e.g. "deepseek" -> fn "buildDeepSeekProvider", const "DEEPSEEK"
# e.g. "glm5"     -> fn "buildGlm5Provider",     const "GLM5"
parts   = provider.replace('-', ' ').replace('_', ' ').split()
fn_cap  = ''.join(p.capitalize() for p in parts)
fn_name = f"build{fn_cap}Provider"
cpfx    = provider.upper().replace('-', '_')

# Model object literals
model_objs = []
for mid, mname, reas in zip(model_ids, model_names, reasoning):
    rs = "true" if reas else "false"
    model_objs.append(
        f'{{ id: "{mid}", name: "{mname}", reasoning: {rs}, input: ["text"], '
        f'cost: {cpfx}_DEFAULT_COST, '
        f'contextWindow: {cpfx}_DEFAULT_CONTEXT_WINDOW, '
        f'maxTokens: {cpfx}_DEFAULT_MAX_TOKENS }}'
    )

BUILD_CODE = (
    f'const {cpfx}_BASE_URL = "{base_url}";\n'
    f'const {cpfx}_DEFAULT_CONTEXT_WINDOW = 64e3;\n'
    f'const {cpfx}_DEFAULT_MAX_TOKENS = 8192;\n'
    f'const {cpfx}_DEFAULT_COST = {{ input: 0, output: 0, cacheRead: 0, cacheWrite: 0 }};\n'
    f'function {fn_name}() {{\n'
    f'\treturn {{\n'
    f'\t\tbaseUrl: {cpfx}_BASE_URL,\n'
    f'\t\tapi: "{api_type}",\n'
    f'\t\tmodels: [\n'
    f'\t\t\t' + ',\n\t\t\t'.join(model_objs) + '\n'
    f'\t\t]\n'
    f'\t}};\n'
    f'}}'
)

REGISTER_CODE = (
    f'\tconst {provider}Key = resolveEnvApiKeyVarName("{provider}") ?? resolveApiKeyFromProfiles({{\n'
    f'\t\tprovider: "{provider}",\n'
    f'\t\tstore: authStore\n'
    f'\t}});\n'
    f'\tif ({provider}Key) providers.{provider} = {{\n'
    f'\t\t...{fn_name}(),\n'
    f'\t\tapiKey: {provider}Key\n'
    f'\t}};'
)

dist_dir      = os.path.join(module_dir, 'dist')
found = patched = skipped = failed = 0

for root, dirs, files in os.walk(dist_dir):
    dirs[:] = [d for d in dirs if d != 'node_modules']
    for fname in sorted(files):
        if not fname.endswith('.js'):
            continue
        fpath = os.path.join(root, fname)
        try:
            content = open(fpath, encoding='utf-8', errors='ignore').read()
        except Exception:
            continue
        if 'resolveEnvApiKey' not in content:
            continue

        found += 1
        rel = os.path.relpath(fpath, module_dir)

        # Skip if already patched (either spacing variant)
        if f'{provider}: "{env_var}"' in content or f"{provider}: '{env_var}'" in content:
            print(f"  SKIP (already patched): {rel}", flush=True)
            skipped += 1
            continue

        original = content
        edits    = []

        # ── Edit 1: add to envVar lookup map ──────────────────────────────
        # The map closes with "\n\t}[normalized]". Find that position and
        # insert ",\n\t\tprovider: "ENV_VAR"" before the closing brace.
        marker = '\n\t}[normalized]'
        pos = content.find(marker)
        if pos != -1 and f'"{env_var}"' not in content[:pos + 1]:
            last_nl  = content.rfind('\n', 0, pos)
            prev_line = content[last_nl + 1:pos] if last_nl != -1 else ''
            sep = ',' if not prev_line.rstrip().endswith(',') else ''
            insert = f'{sep}\n\t\t{provider}: "{env_var}"'
            content = content[:pos] + insert + content[pos:]
            edits.append('envVar map')

        # ── Edit 2: add buildProvider() before buildQwenPortalProvider() ──
        qwen_anchor = '\nfunction buildQwenPortalProvider()'
        if qwen_anchor in content and fn_name not in content:
            content = content.replace(
                qwen_anchor,
                f'\n{BUILD_CODE}\n{qwen_anchor[1:]}',
                1
            )
            edits.append('buildProvider fn')

        # ── Edit 3: register provider before syntheticKey block ───────────
        synth_anchor = '\n\tconst syntheticKey = resolveEnvApiKeyVarName("synthetic")'
        if synth_anchor in content and f'{provider}Key' not in content:
            content = content.replace(
                synth_anchor,
                f'\n{REGISTER_CODE}{synth_anchor[1:]}',
                1
            )
            edits.append('registration')

        if content != original:
            try:
                open(fpath, 'w', encoding='utf-8').write(content)
                print(f"  PATCHED [{', '.join(edits)}]: {rel}", flush=True)
                patched += 1
            except Exception as e:
                print(f"  ERROR writing {rel}: {e}", flush=True)
                failed += 1
        else:
            print(f"  UNCHANGED (no matching patterns): {rel}", flush=True)

print(f"\n  Result: {found} target files — {patched} patched, {skipped} already patched, {failed} errors",
      flush=True)
sys.exit(1 if failed > 0 else 0)
PYEOF

    local py_exit=$?
    if [ $py_exit -eq 0 ]; then
        ok "openclaw JS patching complete for '$provider'."
        clear_openclaw_caches
    else
        warn "openclaw JS patching reported errors for '$provider'. Check output above."
    fi
}

###############################################################################
# Write auth.profiles entry into openclaw.json for a provider
# Maps MODEL_AUTH_TYPE (apikey/oauth/token) to the openclaw mode value.
###############################################################################
update_openclaw_auth_profile() {
    local provider="$1"
    local authtype="${2:-apikey}"

    # Map codeshield auth type to openclaw auth.profiles mode
    local mode
    case "$authtype" in
        apikey) mode="api_key" ;;
        oauth)  mode="oauth"   ;;
        token)  mode="token"   ;;
        *)      mode="api_key" ;;
    esac

    local json_files=()
    local candidate=""
    while IFS= read -r candidate; do
        [ -f "$candidate" ] && json_files+=("$candidate")
    done < <(openclaw_json_paths)
    if [ "${#json_files[@]}" -eq 0 ]; then
        warn "openclaw.json not found. Skipping auth profile update for '$provider'."
        return 0
    fi

    info "Writing auth.profiles for '$provider' (mode=$mode) ..."
    python3 - "$provider" "$mode" "${json_files[@]}" << 'PYEOF'
import sys, json

provider = sys.argv[1]
mode = sys.argv[2]
json_files = sys.argv[3:]
profile_key = f"{provider}:default"

for json_file in json_files:
    with open(json_file, encoding='utf-8') as f:
        cfg = json.load(f)
    profiles = cfg.setdefault('auth', {}).setdefault('profiles', {})
    desired = {'provider': provider, 'mode': mode}
    if profiles.get(profile_key) != desired:
        profiles[profile_key] = desired
        with open(json_file, 'w', encoding='utf-8') as f:
            json.dump(cfg, f, ensure_ascii=False, indent=2)
        print(f"  [{json_file}] auth profile '{profile_key}' written", flush=True)
    else:
        print(f"  [{json_file}] auth profile '{profile_key}' already up to date", flush=True)
PYEOF
}

###############################################################################
# Whitelist provider models in openclaw.json (agents.defaults.models)
###############################################################################
update_openclaw_model_whitelist() {
    local provider="$1"
    local model_refs="${OPENCLAW_MODEL_REFS[$provider]:-}"
    if [ -z "$model_refs" ]; then
        return 0
    fi

    local json_files=()
    local candidate=""
    while IFS= read -r candidate; do
        [ -f "$candidate" ] && json_files+=("$candidate")
    done < <(openclaw_json_paths)
    if [ "${#json_files[@]}" -eq 0 ]; then
        warn "openclaw.json not found. Skipping model whitelist update for '$provider'."
        return 0
    fi

    info "Updating openclaw.json model whitelist for '$provider' ..."
    # shellcheck disable=SC2086
    python3 - "${json_files[@]}" -- $model_refs << 'PYEOF'
import sys, json
args = sys.argv[1:]
split = args.index('--')
json_files = args[:split]
model_refs = args[split + 1:]

for json_file in json_files:
    with open(json_file, encoding='utf-8') as f:
        cfg = json.load(f)
    cfg.setdefault('agents', {}).setdefault('defaults', {}).setdefault('models', {})
    models = cfg['agents']['defaults']['models']
    added = [r for r in model_refs if r not in models]
    for r in added:
        models[r] = {}
    if added:
        with open(json_file, 'w', encoding='utf-8') as f:
            json.dump(cfg, f, ensure_ascii=False, indent=2)
        print(f"  [{json_file}] added: {', '.join(added)}", flush=True)
    else:
        print(f"  [{json_file}] model whitelist already up to date", flush=True)
PYEOF
}

###############################################################################
# Write non-native provider definitions into openclaw.json (models.providers)
###############################################################################
update_openclaw_model_provider_config() {
    local provider="$1"
    local patch_data="${OPENCLAW_JS_PATCH_PROVIDERS[$provider]:-}"
    if [ -z "$patch_data" ]; then
        return 0
    fi

    local json_files=()
    local candidate=""
    while IFS= read -r candidate; do
        [ -f "$candidate" ] && json_files+=("$candidate")
    done < <(openclaw_json_paths)
    if [ "${#json_files[@]}" -eq 0 ]; then
        warn "openclaw.json not found. Skipping models.providers update for '$provider'."
        return 0
    fi

    local env_var=""
    local base_url=""
    local api_type=""
    local model_ids=""
    local model_names=""
    local reasoning_flags=""
    IFS='|' read -r env_var base_url api_type model_ids model_names reasoning_flags <<< "$patch_data"

    info "Writing models.providers config for '$provider' ..."
    python3 - "$provider" "$env_var" "$base_url" "$api_type" \
        "$model_ids" "$model_names" "$reasoning_flags" "${json_files[@]}" << 'PYEOF'
import json
import sys

provider = sys.argv[1]
env_var = sys.argv[2]
base_url = sys.argv[3]
api_type = sys.argv[4]
model_ids = sys.argv[5].split(',')
model_names = sys.argv[6].split(',')
reasoning = [r.strip() == 'true' for r in sys.argv[7].split(',')]
json_files = sys.argv[8:]

models = []
for mid, mname, reas in zip(model_ids, model_names, reasoning):
    models.append({
        'id': mid,
        'name': mname,
        'reasoning': reas,
        'input': ['text'],
    })

desired = {
    'baseUrl': base_url,
    'api': api_type,
    'auth': 'api-key',
    'apiKey': f'${{{env_var}}}',
    'models': models,
}

for json_file in json_files:
    with open(json_file, encoding='utf-8') as f:
        cfg = json.load(f)
    providers = cfg.setdefault('models', {}).setdefault('providers', {})
    current = providers.get(provider)
    auth_cfg = cfg.get('auth')
    if isinstance(auth_cfg, dict):
        auth_providers = auth_cfg.get('providers')
        if isinstance(auth_providers, dict):
            auth_providers.pop(provider, None)
            if not auth_providers:
                auth_cfg.pop('providers', None)
    if current != desired:
        providers[provider] = desired
        with open(json_file, 'w', encoding='utf-8') as f:
            json.dump(cfg, f, ensure_ascii=False, indent=2)
            f.write('\n')
        print(f"  [{json_file}] models.providers.{provider} updated", flush=True)
    else:
        print(f"  [{json_file}] models.providers.{provider} already up to date", flush=True)
PYEOF

    local json_file=""
    for json_file in "${json_files[@]}"; do
        local owner="openclaw"
        [ "$json_file" = "/var/lib/openclaw-svc/.openclaw/openclaw.json" ] && owner="openclaw-svc"
        chown "${owner}:${owner}" "$json_file" 2>/dev/null || true
        chmod 0600 "$json_file" 2>/dev/null || true
    done
}

###############################################################################
# QMD backend management for OpenClaw built-in retrieval
###############################################################################
openclaw_json_paths() {
    printf '%s\n' '/home/openclaw/.openclaw/openclaw.json'
    if id openclaw-svc >/dev/null 2>&1; then
        printf '%s\n' '/var/lib/openclaw-svc/.openclaw/openclaw.json'
    fi
}

workspace_path_for_json() {
    local json_file="$1"
    if [ "$json_file" = "/var/lib/openclaw-svc/.openclaw/openclaw.json" ]; then
        printf '%s\n' '/var/lib/openclaw-svc/.openclaw/workspace'
    else
        printf '%s\n' '/home/openclaw/.openclaw/workspace'
    fi
}

cmd_qmd_backend() {
    require_root

    local action="${1:-show}"
    shift || true
    local do_restart=true

    while [ $# -gt 0 ]; do
        case "$1" in
            --no-restart) do_restart=false ;;
            *)
                fail "Unknown qmd-backend option: $1"
                exit 1
                ;;
        esac
        shift
    done

    case "$action" in
        show)
            python3 - <<'PYEOF'
import json
from pathlib import Path

for raw_path in [Path('/home/openclaw/.openclaw/openclaw.json'), Path('/var/lib/openclaw-svc/.openclaw/openclaw.json')]:
    print(f'[{raw_path}]')
    if not raw_path.exists():
        print('  status: missing')
        continue
    try:
        cfg = json.loads(raw_path.read_text(encoding='utf-8'))
    except Exception as exc:
        print(f'  status: invalid-json ({exc})')
        continue
    memory = cfg.get('memory') or {}
    qmd = memory.get('qmd') or {}
    print(f"  backend: {memory.get('backend', 'builtin')}")
    print(f"  command: {qmd.get('command', '(unset)')}")
    print(f"  searchMode: {qmd.get('searchMode', '(default)')}")
    print(f"  includeDefaultMemory: {qmd.get('includeDefaultMemory', '(default)')}")
    limits = qmd.get('limits') or {}
    print(f"  timeoutMs: {limits.get('timeoutMs', '(default)')}")
    print(f"  maxResults: {limits.get('maxResults', '(default)')}")
    paths = qmd.get('paths') or []
    print(f"  paths: {len(paths)}")
    for item in paths[:10]:
        print(f"    - {item.get('name', '(unnamed)')}: {item.get('path', '(missing)')}")
PYEOF
            ;;
        enable)
            if [ ! -x /home/openclaw/scripts/qmd-openclaw-wrapper.sh ]; then
                warn "QMD wrapper not found at /home/openclaw/scripts/qmd-openclaw-wrapper.sh"
                warn "Install or update the custom_qmd deployment before enabling the backend."
            fi

            while IFS= read -r json_file; do
                local owner="openclaw"
                local workspace_path
                [ "$json_file" = "/var/lib/openclaw-svc/.openclaw/openclaw.json" ] && owner="openclaw-svc"
                workspace_path="$(workspace_path_for_json "$json_file")"
                mkdir -p "$(dirname "$json_file")"
                mkdir -p "$workspace_path"
                python3 - "$json_file" "$workspace_path" <<'PYEOF'
import json, sys
from pathlib import Path

path = Path(sys.argv[1])
workspace_path = sys.argv[2]
cfg = {}
if path.exists():
    try:
        cfg = json.loads(path.read_text(encoding='utf-8'))
    except (OSError, json.JSONDecodeError):
        cfg = {}

qmd_root = Path('/home/openclaw/qmd-index')
paths = []
if qmd_root.is_dir():
    for child in sorted(qmd_root.iterdir()):
        if child.is_dir():
            paths.append({
                'name': child.name,
                'path': str(child),
                'pattern': '**/*.md',
            })
    if not paths:
        paths.append({
            'name': 'qmd-index',
            'path': str(qmd_root),
            'pattern': '**/*.md',
        })

memory = cfg.setdefault('memory', {})
memory['backend'] = 'qmd'
memory['citations'] = memory.get('citations') or 'auto'
qmd = memory.setdefault('qmd', {})
qmd['command'] = '/home/openclaw/scripts/qmd-openclaw-wrapper.sh'
qmd['searchMode'] = qmd.get('searchMode') or 'search'
qmd['includeDefaultMemory'] = False
qmd['limits'] = {'maxResults': 6, 'timeoutMs': 15000}
qmd['paths'] = paths
qmd['mcporter'] = {'enabled': False}
update = qmd.get('update') if isinstance(qmd.get('update'), dict) else {}
update['onBoot'] = False
update['waitForBootSync'] = False
qmd['update'] = update
defaults = cfg.setdefault('agents', {}).setdefault('defaults', {})
defaults['workspace'] = workspace_path
defaults.setdefault('memorySearch', {})['enabled'] = True

with open(path, 'w', encoding='utf-8') as f:
    json.dump(cfg, f, ensure_ascii=False, indent=2)
    f.write('\n')
PYEOF
                chown "${owner}:${owner}" "$json_file"
                chmod 0600 "$json_file"
                ok "Configured OpenClaw QMD backend in $json_file"
            done < <(openclaw_json_paths)

            if [ "$do_restart" = true ]; then
                restart_openclaw
            else
                info 'Skipped openclaw restart (--no-restart).'
            fi
            ;;
        disable)
            while IFS= read -r json_file; do
                [ -f "$json_file" ] || continue
                local owner="openclaw"
                [ "$json_file" = "/var/lib/openclaw-svc/.openclaw/openclaw.json" ] && owner="openclaw-svc"
                python3 - "$json_file" <<'PYEOF'
import json, sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    cfg = json.loads(path.read_text(encoding='utf-8'))
except (OSError, json.JSONDecodeError):
    cfg = {}
mem = cfg.setdefault('memory', {})
mem['backend'] = 'builtin'
mem.pop('qmd', None)
with open(path, 'w', encoding='utf-8') as f:
    json.dump(cfg, f, ensure_ascii=False, indent=2)
    f.write('\n')
PYEOF
                chown "${owner}:${owner}" "$json_file"
                chmod 0600 "$json_file"
                ok "Disabled OpenClaw QMD backend in $json_file"
            done < <(openclaw_json_paths)

            if [ "$do_restart" = true ]; then
                restart_openclaw
            else
                info 'Skipped openclaw restart (--no-restart).'
            fi
            ;;
        *)
            fail "Usage: codeshield-config qmd-backend [enable|show|disable] [--no-restart]"
            exit 1
            ;;
    esac
}

###############################################################################
# Command: show
###############################################################################
cmd_show() {
    require_root
    ensure_dirs
    decrypt_secrets

    printf "\n${BOLD}${CYAN}=== CODE SHIELD Configuration ===${RESET}\n\n"

    # Show secrets (masked)
    printf "${BOLD}Secrets:${RESET}\n"
    while IFS= read -r line; do
        [[ "$line" =~ ^#.*$ ]] && continue
        [[ -z "$line" ]] && continue
        local key val
        key="${line%%=*}"
        val="${line#*=}"
        if [ -n "$val" ]; then
            printf "  %-30s = %s\n" "$key" "$(mask_secret "$val")"
        else
            printf "  %-30s = ${YELLOW}(not set)${RESET}\n" "$key"
        fi
    done < "$SECRETS_FILE"

    # Show channels
    printf "\n${BOLD}Channels:${RESET}\n"
    if [ -d "$CHANNELS_DIR" ] && ls "$CHANNELS_DIR"/*.conf &>/dev/null 2>&1; then
        for cf in "$CHANNELS_DIR"/*.conf; do
            local name domains
            name=$(grep -E '^CHANNEL_NAME=' "$cf" 2>/dev/null | cut -d'=' -f2-)
            domains=$(grep -E '^CHANNEL_DOMAINS=' "$cf" 2>/dev/null | cut -d'=' -f2-)
            printf "  %-20s domains: %s\n" "$name" "$domains"
        done
    else
        printf "  ${YELLOW}(none configured)${RESET}\n"
    fi

    # Show models
    printf "\n${BOLD}LLM Providers:${RESET}\n"
    if [ -d "$MODELS_DIR" ] && ls "$MODELS_DIR"/*.conf &>/dev/null 2>&1; then
        for mf in "$MODELS_DIR"/*.conf; do
            local name domains auth
            name=$(grep -E '^MODEL_NAME=' "$mf" 2>/dev/null | cut -d'=' -f2-)
            domains=$(grep -E '^MODEL_DOMAINS=' "$mf" 2>/dev/null | cut -d'=' -f2-)
            auth=$(grep -E '^MODEL_AUTH_TYPE=' "$mf" 2>/dev/null | cut -d'=' -f2-)
            printf "  %-20s domains: %-30s auth: %s\n" "$name" "$domains" "$auth"
        done
    else
        printf "  ${YELLOW}(none configured -- OpenAI default via secrets.env)${RESET}\n"
    fi

    # Show whitelist
    printf "\n${BOLD}Proxy Whitelist (additional):${RESET}\n"
    if [ -f "$WHITELIST_FILE" ]; then
        while IFS= read -r line; do
            [[ "$line" =~ ^#.*$ ]] && continue
            [[ -z "$line" ]] && continue
            printf "  %s\n" "$line"
        done < "$WHITELIST_FILE"
        local count
        count=$(grep -cvE '^\s*(#|$)' "$WHITELIST_FILE" 2>/dev/null || echo 0)
        if [ "$count" -eq 0 ]; then
            printf "  ${YELLOW}(none)${RESET}\n"
        fi
    else
        printf "  ${YELLOW}(none)${RESET}\n"
    fi

    printf "\n"
}

###############################################################################
# Command: edit
###############################################################################
cmd_edit() {
    require_root
    ensure_dirs
    decrypt_secrets

    printf "\n${BOLD}${CYAN}=== Interactive Secret Editor ===${RESET}\n"
    printf "Press Enter to keep current value. Enter new value to change.\n\n"

    local changed=0

    while IFS= read -r line; do
        [[ "$line" =~ ^#.*$ ]] && continue
        [[ -z "$line" ]] && continue
        local key val newval
        key="${line%%=*}"
        val="${line#*=}"

        printf "${BOLD}%s${RESET} [current: %s]: " "$key" "$(mask_secret "$val")" >/dev/tty
        read -r newval </dev/tty

        if [ -n "$newval" ]; then
            write_secret "$key" "$newval"
            ok "Updated $key" >/dev/tty
            changed=1
        fi
    done < "$SECRETS_FILE"

    if [ "$changed" -eq 1 ]; then
        reencrypt_secrets
        restart_openclaw
    else
        info "No changes made."
    fi
}

###############################################################################
# Command: set KEY=VALUE
###############################################################################
cmd_set() {
    require_root
    ensure_dirs
    decrypt_secrets

    local input="$1"
    local key="${input%%=*}"
    local value="${input#*=}"

    if [ "$key" = "$input" ] || [ -z "$key" ]; then
        fail "Usage: codeshield-config set KEY=VALUE"
        exit 1
    fi

    write_secret "$key" "$value"
    ok "Set $key = $(mask_secret "$value")"

    reencrypt_secrets
    restart_openclaw
}

###############################################################################
# Command: add-channel
###############################################################################
cmd_add_channel() {
    require_root
    ensure_dirs
    decrypt_secrets

    # Built-in channel definitions
    declare -A BUILTIN_CH_NAMES=(
        [wecom]="企业微信 (WeCom)"
        [feishu]="飞书 (Feishu)"
        [discord]="Discord"
    )
    declare -A BUILTIN_CH_DOMAINS=(
        [wecom]="qyapi.weixin.qq.com"
        [feishu]="open.feishu.cn"
        [discord]="discord.com,cdn.discordapp.com"
    )
    declare -A BUILTIN_CH_VARS=(
        [wecom]="WECOM_CORP_ID,WECOM_AGENT_ID,WECOM_SECRET"
        [feishu]="FEISHU_APP_ID,FEISHU_APP_SECRET"
        [discord]="DISCORD_BOT_TOKEN,DISCORD_WEBHOOK_URL"
    )

    printf "\n${BOLD}${CYAN}=== Add New Channel / 添加通道 ===${RESET}\n\n"
    printf "Select a channel type:\n"
    printf "  ${BOLD}1${RESET}) 企业微信 (WeCom)\n"
    printf "  ${BOLD}2${RESET}) 飞书 (Feishu)\n"
    printf "  ${BOLD}3${RESET}) Discord\n"
    printf "  ${BOLD}4${RESET}) Custom (自定义)\n"
    printf "\nChoice [1-4]: " >/dev/tty
    local ch_choice
    read -r ch_choice </dev/tty

    local name domains varnames
    local channel_key=""

    case "$ch_choice" in
        1) channel_key="wecom" ;;
        2) channel_key="feishu" ;;
        3) channel_key="discord" ;;
        4) channel_key="custom" ;;
        *) fail "Invalid choice."; exit 1 ;;
    esac

    if [ "$channel_key" != "custom" ]; then
        name="${BUILTIN_CH_NAMES[$channel_key]}"
        domains="${BUILTIN_CH_DOMAINS[$channel_key]}"
        varnames="${BUILTIN_CH_VARS[$channel_key]}"
        printf "\n${BOLD}Adding: %s${RESET}\n" "$name"
        printf "  Domains: %s\n" "$domains"
        printf "  Variables: %s\n\n" "$varnames"
    else
        # Custom channel: manual input
        printf "\n${BOLD}Channel name${RESET} (e.g. slack, dingtalk, telegram): " >/dev/tty
        read -r name </dev/tty
        if [ -z "$name" ]; then
            fail "Channel name is required."
            exit 1
        fi

        printf "${BOLD}API domains${RESET} (comma-separated, e.g. api.slack.com,hooks.slack.com): " >/dev/tty
        read -r domains </dev/tty
        if [ -z "$domains" ]; then
            fail "At least one domain is required."
            exit 1
        fi

        while true; do
            printf "${BOLD}Environment variable names${RESET} (comma-separated, e.g. SLACK_BOT_TOKEN,SLACK_WEBHOOK_URL): " >/dev/tty
            read -r varnames </dev/tty

            if [ -n "$varnames" ]; then
                local valid=1
                IFS=',' read -ra check_vars <<< "$varnames"
                for cv in "${check_vars[@]}"; do
                    cv=$(printf '%s' "$cv" | tr -d ' ')
                    if ! printf '%s' "$cv" | grep -qE '^[A-Za-z_][A-Za-z0-9_]*$'; then
                        fail "Invalid variable name: '$cv'" >/dev/tty
                        fail "Variable names must contain only letters, digits, and underscores (e.g. TELEGRAM_BOT_TOKEN)." >/dev/tty
                        fail "Do NOT enter the actual secret value here — only the variable NAME." >/dev/tty
                        valid=0
                        break
                    fi
                done
                [ "$valid" -eq 1 ] && break
            else
                break
            fi
        done
    fi

    # Sanitize name for filename
    local safename
    if [ "$channel_key" != "custom" ]; then
        safename="$channel_key"
    else
        safename=$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9_-')
    fi

    if [ -f "$CHANNELS_DIR/${safename}.conf" ]; then
        warn "Channel '$safename' already exists. Overwriting."
    fi

    # Collect values for each variable
    if [ -n "$varnames" ]; then
        IFS=',' read -ra vars <<< "$varnames"
        for var in "${vars[@]}"; do
            var=$(printf '%s' "$var" | tr -d ' ')
            local existing
            existing=$(read_secret "$var")
            if [ -n "$existing" ]; then
                printf "  ${BOLD}%s${RESET} [current: %s] (Enter to keep): " "$var" "$(mask_secret "$existing")" >/dev/tty
            else
                printf "  ${BOLD}%s${RESET}: " "$var" >/dev/tty
            fi
            local val
            read -r val </dev/tty
            if [ -n "$val" ]; then
                write_secret "$var" "$val"
                ok "Stored $var"
            fi
        done
    fi

    # Write channel conf
    cat > "$CHANNELS_DIR/${safename}.conf" << CHEOF
# CODE SHIELD -- Channel: $name
CHANNEL_NAME=$name
CHANNEL_DOMAINS=$domains
CHANNEL_VARS=$varnames
CHEOF
    chmod 0600 "$CHANNELS_DIR/${safename}.conf"
    ok "Channel config written: $CHANNELS_DIR/${safename}.conf"

    # Update whitelist
    IFS=',' read -ra doms <<< "$domains"
    for d in "${doms[@]}"; do
        d=$(printf '%s' "$d" | tr -d ' ')
        add_to_whitelist "$d"
    done

    reencrypt_secrets
    restart_codeshield_secrets
    reload_squid
    restart_openclaw

    printf "\n${GREEN}Channel '$name' added successfully.${RESET}\n"
}

###############################################################################
# Command: add-model [provider]
###############################################################################
cmd_add_model() {
    require_root
    ensure_dirs
    decrypt_secrets

    local provider="${1:-}"

    # Built-in provider definitions
    declare -A BUILTIN_NAMES=(
        [openai]="OpenAI"
        [openai-oauth]="OpenAI (OAuth / OpenClaw Native)"
        [anthropic]="Anthropic / Claude"
        [deepseek]="DeepSeek (深度求索)"
        [glm5]="GLM5 (智谱 BigModel)"
        [kimi]="Kimi (月之暗面 Moonshot)"
        [minimax]="MiniMax"
    )
    declare -A BUILTIN_DOMAINS=(
        [openai]="api.openai.com"
        [openai-oauth]="api.openai.com,auth.openai.com,auth0.openai.com"
        [anthropic]="api.anthropic.com"
        [deepseek]="api.deepseek.com"
        [glm5]="open.bigmodel.cn"
        [kimi]="api.moonshot.cn"
        [minimax]="api.minimax.io"
    )
    declare -A BUILTIN_VARS=(
        [openai]="OPENAI_API_KEY"
        [openai-oauth]=""
        [anthropic]="ANTHROPIC_API_KEY"
        [deepseek]="DEEPSEEK_API_KEY"
        [glm5]="GLM_API_KEY"
        [kimi]="KIMI_API_KEY"
        [minimax]="MINIMAX_API_KEY,MINIMAX_GROUP_ID"
    )
    declare -A BUILTIN_AUTH=(
        [openai]="apikey"
        [openai-oauth]="oauth"
        [anthropic]="apikey"
        [deepseek]="apikey"
        [glm5]="apikey"
        [kimi]="apikey"
        [minimax]="apikey"
    )
    declare -A BUILTIN_SETUP_FLOW=(
        [openai]="codeshield-secret"
        [openai-oauth]="openclaw-oauth"
        [anthropic]="codeshield-secret"
        [deepseek]="codeshield-secret"
        [glm5]="codeshield-secret"
        [kimi]="codeshield-secret"
        [minimax]="codeshield-secret"
    )
    declare -A BUILTIN_OPENCLAW_PROVIDER=(
        [openai]="openai"
        [openai-oauth]="openai-codex"
        [anthropic]="anthropic"
        [deepseek]="deepseek"
        [glm5]="glm5"
        [kimi]="kimi"
        [minimax]="minimax"
    )

    if [ -z "$provider" ]; then
        printf "\n${BOLD}${CYAN}=== Add LLM Provider / 添加大模型 ===${RESET}\n\n"
        printf "Select a provider:\n"
        printf "  ${BOLD}1${RESET}) OpenAI (API Key)\n"
        printf "  ${BOLD}2${RESET}) OpenAI (OAuth)\n"
        printf "  ${BOLD}3${RESET}) Anthropic / Claude\n"
        printf "  ${BOLD}4${RESET}) DeepSeek (深度求索)\n"
        printf "  ${BOLD}5${RESET}) GLM5 (智谱 BigModel)\n"
        printf "  ${BOLD}6${RESET}) Kimi (月之暗面 Moonshot)\n"
        printf "  ${BOLD}7${RESET}) MiniMax\n"
        printf "  ${BOLD}8${RESET}) Custom (自定义)\n"
        printf "\nChoice [1-8]: " >/dev/tty
        local choice
        read -r choice </dev/tty
        case "$choice" in
            1) provider="openai" ;;
            2) provider="openai-oauth" ;;
            3) provider="anthropic" ;;
            4) provider="deepseek" ;;
            5) provider="glm5" ;;
            6) provider="kimi" ;;
            7) provider="minimax" ;;
            8) provider="custom" ;;
            *) fail "Invalid choice."; exit 1 ;;
        esac
    fi

    local name domains varnames authtype setupflow openclaw_provider

    if [ "$provider" = "custom" ]; then
        printf "\n${BOLD}Provider name${RESET}: " >/dev/tty
        read -r name </dev/tty
        [ -z "$name" ] && { fail "Name is required."; exit 1; }

        printf "${BOLD}API domains${RESET} (comma-separated): " >/dev/tty
        read -r domains </dev/tty
        [ -z "$domains" ] && { fail "At least one domain is required."; exit 1; }

        while true; do
            printf "${BOLD}Environment variable names${RESET} (comma-separated): " >/dev/tty
            read -r varnames </dev/tty
            if [ -n "$varnames" ]; then
                local valid=1
                IFS=',' read -ra check_vars <<< "$varnames"
                for cv in "${check_vars[@]}"; do
                    cv=$(printf '%s' "$cv" | tr -d ' ')
                    if ! printf '%s' "$cv" | grep -qE '^[A-Za-z_][A-Za-z0-9_]*$'; then
                        fail "Invalid variable name: '$cv'. Use UPPER_CASE names like MY_API_KEY." >/dev/tty
                        valid=0; break
                    fi
                done
                [ "$valid" -eq 1 ] && break
            else
                break
            fi
        done

        printf "${BOLD}Auth type${RESET} (apikey/oauth) [apikey]: " >/dev/tty
        read -r authtype </dev/tty
        authtype="${authtype:-apikey}"
        setupflow="codeshield-secret"
        openclaw_provider="custom"
    else
        name="${BUILTIN_NAMES[$provider]}"
        domains="${BUILTIN_DOMAINS[$provider]}"
        varnames="${BUILTIN_VARS[$provider]}"
        authtype="${BUILTIN_AUTH[$provider]}"
        setupflow="${BUILTIN_SETUP_FLOW[$provider]}"
        openclaw_provider="${BUILTIN_OPENCLAW_PROVIDER[$provider]}"
        printf "\n${BOLD}Adding: %s${RESET}\n" "$name"
        printf "  Domains: %s\n" "$domains"
        printf "  Variables: %s\n" "${varnames:-"(managed by runtime OAuth)"}"
        printf "  Auth: %s\n\n" "$authtype"
    fi

    # Sanitize provider name for filename
    local safename
    safename=$(printf '%s' "$provider" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9_-')

    # Collect variable values
    if [ -n "$varnames" ]; then
        IFS=',' read -ra vars <<< "$varnames"
        for var in "${vars[@]}"; do
            var=$(printf '%s' "$var" | tr -d ' ')
            local existing
            existing=$(read_secret "$var")
            if [ -n "$existing" ]; then
                printf "  ${BOLD}%s${RESET} [current: %s] (Enter to keep): " "$var" "$(mask_secret "$existing")" >/dev/tty
            else
                printf "  ${BOLD}%s${RESET}: " "$var" >/dev/tty
            fi
            local val
            read -r val </dev/tty
            if [ -n "$val" ]; then
                write_secret "$var" "$val"
                ok "Stored $var"
            fi
        done
    fi

    # Write model conf
    cat > "$MODELS_DIR/${safename}.conf" << MEOF
# CODE SHIELD -- LLM Provider: $name
MODEL_NAME=$name
MODEL_DOMAINS=$domains
MODEL_VARS=$varnames
MODEL_AUTH_TYPE=$authtype
MODEL_SETUP_FLOW=$setupflow
MODEL_OPENCLAW_PROVIDER=$openclaw_provider
MEOF
    chmod 0600 "$MODELS_DIR/${safename}.conf"
    ok "Model config written: $MODELS_DIR/${safename}.conf"

    # Update whitelist
    IFS=',' read -ra doms <<< "$domains"
    for d in "${doms[@]}"; do
        d=$(printf '%s' "$d" | tr -d ' ')
        add_to_whitelist "$d"
    done

    # Patch openclaw JS files for non-native providers (e.g. deepseek, glm5)
    patch_openclaw_provider "$safename"

    # Write runtime models.providers config for non-native providers on newer openclaw
    update_openclaw_model_provider_config "$safename"

    # Whitelist provider models in openclaw.json
    update_openclaw_model_whitelist "$safename"

    # Write auth profile so openclaw recognises the provider credentials
    update_openclaw_auth_profile "$openclaw_provider" "$authtype"

    reencrypt_secrets
    reload_squid
    restart_openclaw

    if [ "$provider" = "openai-oauth" ]; then
        local openclaw_bin
        openclaw_bin=$(find_openclaw_bin || true)
        print_openai_oauth_next_steps "${openclaw_bin:-/home/openclaw/.npm-global/bin/openclaw}"
    fi

    printf "\n${GREEN}LLM provider '%s' added successfully.${RESET}\n" "$name"
}

###############################################################################
# Command: patch-provider <provider>
###############################################################################
cmd_patch_provider() {
    require_root
    local provider="${1:-}"
    if [ -z "$provider" ]; then
        fail "Usage: codeshield-config patch-provider <provider>"
        printf "  Supported: %s\n" "${!OPENCLAW_JS_PATCH_PROVIDERS[*]}"
        exit 1
    fi
    if [ -z "${OPENCLAW_JS_PATCH_PROVIDERS[$provider]:-}" ]; then
        info "'$provider' is natively supported by openclaw — no JS patching needed."
        exit 0
    fi
    patch_openclaw_provider "$provider"
    update_openclaw_model_provider_config "$provider"
    update_openclaw_model_whitelist "$provider"
    ok "patch-provider '$provider' complete."
}

###############################################################################
# Command: list-channels
###############################################################################
cmd_list_channels() {
    printf "\n${BOLD}Configured Channels:${RESET}\n"
    if [ -d "$CHANNELS_DIR" ] && ls "$CHANNELS_DIR"/*.conf &>/dev/null 2>&1; then
        for cf in "$CHANNELS_DIR"/*.conf; do
            local name domains vars
            name=$(grep -E '^CHANNEL_NAME=' "$cf" 2>/dev/null | cut -d'=' -f2-)
            domains=$(grep -E '^CHANNEL_DOMAINS=' "$cf" 2>/dev/null | cut -d'=' -f2-)
            vars=$(grep -E '^CHANNEL_VARS=' "$cf" 2>/dev/null | cut -d'=' -f2-)
            printf "  ${BOLD}%-15s${RESET}  domains: %-30s  vars: %s\n" "$name" "$domains" "$vars"
        done
    else
        printf "  ${YELLOW}(none)${RESET}\n"
    fi
    printf "\n"
}

###############################################################################
# Command: list-models
###############################################################################
cmd_list_models() {
    printf "\n${BOLD}Configured LLM Providers:${RESET}\n"
    if [ -d "$MODELS_DIR" ] && ls "$MODELS_DIR"/*.conf &>/dev/null 2>&1; then
        for mf in "$MODELS_DIR"/*.conf; do
            local name domains auth vars
            name=$(grep -E '^MODEL_NAME=' "$mf" 2>/dev/null | cut -d'=' -f2-)
            domains=$(grep -E '^MODEL_DOMAINS=' "$mf" 2>/dev/null | cut -d'=' -f2-)
            auth=$(grep -E '^MODEL_AUTH_TYPE=' "$mf" 2>/dev/null | cut -d'=' -f2-)
            vars=$(grep -E '^MODEL_VARS=' "$mf" 2>/dev/null | cut -d'=' -f2-)
            printf "  ${BOLD}%-20s${RESET}  auth: %-8s  domains: %-30s  vars: %s\n" "$name" "$auth" "$domains" "$vars"
        done
    else
        printf "  ${YELLOW}(none configured -- using secrets.env directly)${RESET}\n"
    fi
    printf "\n"
}

###############################################################################
# Command: proxy-allow
###############################################################################
cmd_proxy_allow() {
    require_root
    local domain="${1:-}"
    if [ -z "$domain" ]; then
        fail "Usage: codeshield-config proxy-allow <domain>"
        exit 1
    fi
    ensure_dirs
    add_to_whitelist "$domain"
    reload_squid
}

###############################################################################
# Command: network-mode
###############################################################################
cmd_network_mode() {
    require_root
    local mode="${1:-}"

    if [ -z "$mode" ]; then
        # Show current mode
        if grep -qE '^\s*http_access allow localnet\s*$' "$SQUID_CONF" 2>/dev/null; then
            printf "Current network mode: ${GREEN}open${RESET} (all domains allowed through proxy)\n"
        elif grep -qE '^\s*http_access allow localnet known_api_domains' "$SQUID_CONF" 2>/dev/null; then
            printf "Current network mode: ${YELLOW}strict${RESET} (known API domains only)\n"
        else
            warn "Could not determine current network mode from $SQUID_CONF"
        fi
        printf "\nUsage: codeshield-config network-mode <open|strict>\n"
        printf "  open    Allow all domains through proxy (default, required for web_fetch)\n"
        printf "  strict  Allow only known API domains (disables web_fetch for arbitrary URLs)\n"
        return
    fi

    case "$mode" in
        open)
            if grep -qE '^\s*http_access allow localnet known_api_domains' "$SQUID_CONF" 2>/dev/null; then
                sed -i 's/^\(\s*\)http_access allow localnet known_api_domains/\1http_access allow localnet/' "$SQUID_CONF"
                reload_squid
                ok "Network mode set to OPEN. All domains allowed through proxy."
            else
                ok "Network mode is already OPEN."
            fi
            ;;
        strict)
            if grep -qE '^\s*http_access allow localnet\s*$' "$SQUID_CONF" 2>/dev/null; then
                sed -i 's/^\(\s*\)http_access allow localnet\s*$/\1http_access allow localnet known_api_domains/' "$SQUID_CONF"
                reload_squid
                ok "Network mode set to STRICT. Only known API domains allowed."
                warn "web_fetch and arbitrary URL access will fail for unlisted domains."
                info "Use 'codeshield-config proxy-allow <domain>' to whitelist additional domains."
            else
                ok "Network mode is already STRICT."
            fi
            ;;
        *)
            fail "Invalid mode: $mode. Use 'open' or 'strict'."
            exit 1
            ;;
    esac
}

###############################################################################
# Command: help
###############################################################################
cmd_help() {
    cat << 'HELPEOF'
CODE SHIELD Configuration Manager

Usage: codeshield-config <command> [args]

Commands:
  show                       Show current configuration (secrets masked)
  edit                       Interactive edit of all secrets
  set KEY=VALUE              Set a single configuration key
  add-channel                Interactive: add a messaging channel (WeCom/Feishu/Discord/Custom)
  add-model [provider]       Add an LLM provider (interactive menu)
                             Providers: openai, openai-oauth, anthropic, deepseek, glm5, kimi, minimax, custom
                             Non-native providers (deepseek, glm5) automatically patch openclaw JS files.
                             openai-oauth uses OpenClaw's native OAuth login flow and does not store client secrets.
  patch-provider <provider>  Manually patch openclaw JS files for a non-native provider.
                             Use after openclaw updates to re-apply provider registration.
                             Supported: deepseek, glm5
  list-channels              List configured channels
  list-models                List configured LLM providers
  proxy-allow <domain>       Add a domain to the Squid proxy whitelist
  network-mode [open|strict] Show or toggle network access mode:
                             open   = all domains through proxy (default)
                             strict = known API domains only (disables web_fetch)
  qmd-backend [enable|show|disable]
                             Manage OpenClaw's built-in QMD backend under Codeshield
  help                       Show this help message

Examples:
  codeshield-config show
  codeshield-config set ANTHROPIC_API_KEY=sk-ant-xxx
  codeshield-config add-model anthropic
  codeshield-config add-model openai-oauth
  codeshield-config add-model deepseek
  codeshield-config add-model minimax
  codeshield-config add-channel
  codeshield-config proxy-allow api.example.com
  codeshield-config patch-provider deepseek
  codeshield-config network-mode              # show current mode
  codeshield-config network-mode open         # allow all domains
  codeshield-config qmd-backend show          # inspect current QMD backend config
  codeshield-config qmd-backend enable        # enable OpenClaw -> QMD retrieval
HELPEOF
}

###############################################################################
# Main dispatch
###############################################################################
main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        show)           cmd_show ;;
        edit)           cmd_edit ;;
        set)            cmd_set "${1:-}" ;;
        add-channel)    cmd_add_channel ;;
        add-model)      cmd_add_model "${1:-}" ;;
        patch-provider) cmd_patch_provider "${1:-}" ;;
        list-channels)  cmd_list_channels ;;
        list-models)    cmd_list_models ;;
        proxy-allow)    cmd_proxy_allow "${1:-}" ;;
        network-mode)   cmd_network_mode "${1:-}" ;;
        qmd-backend)    cmd_qmd_backend "$@" ;;
        help|--help|-h) cmd_help ;;
        *)
            fail "Unknown command: $cmd"
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
