#!/usr/bin/env bash
# CODE SHIELD V3 — One-time migration from plaintext secrets.env to encrypted
#
# This script:
#   1. Encrypts existing secrets.env → secrets.env.enc (systemd-creds, host key)
#   2. Updates systemd drop-in to read from /run/ (tmpfs)
#   3. Enables codeshield-secrets.service
#   4. Restarts services with zero downtime
#
# Safe to run multiple times (idempotent).
set -euo pipefail

CS_CONF_DIR="/etc/openclaw-codeshield"
PLAIN_FILE="$CS_CONF_DIR/secrets.env"
ENC_FILE="$CS_CONF_DIR/secrets.env.enc"
DROPIN_DIR="/etc/systemd/system/openclaw.service.d"
DROPIN_FILE="$DROPIN_DIR/codeshield.conf"

echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║  CODE SHIELD — Secrets Encryption Migration     ║"
echo "╚══════════════════════════════════════════════════╝"
echo ""

# Pre-check: host key must exist
if [ ! -f /var/lib/systemd/credential.secret ]; then
    echo "Generating systemd host credential key ..."
    systemd-creds setup
fi

# Step 1: Encrypt if plaintext exists and .enc doesn't (or is older)
if [ -f "$PLAIN_FILE" ]; then
    echo "[1/4] Encrypting secrets.env → secrets.env.enc ..."
    codeshield-secrets-seal --from "$PLAIN_FILE"
    echo "  Done. Plaintext securely wiped."
elif [ -f "$ENC_FILE" ]; then
    echo "[1/4] Encrypted secrets already exist. Skipping."
else
    echo "ERROR: No secrets file found at $PLAIN_FILE" >&2
    exit 1
fi

# Step 2: Update systemd drop-in to point EnvironmentFile to tmpfs
echo "[2/4] Updating systemd drop-in ..."
cat > "$DROPIN_FILE" << 'DROPIN_EOF'
[Unit]
# Ensure secrets are decrypted before we start
After=codeshield-secrets.service
Requires=codeshield-secrets.service

[Service]
# Non-sensitive config (proxy, etc.)
EnvironmentFile=-/etc/openclaw-codeshield/codeshield.env
# Secrets decrypted to tmpfs by codeshield-secrets.service
EnvironmentFile=/run/openclaw-codeshield/secrets.env
DROPIN_EOF

chmod 0644 "$DROPIN_FILE"
echo "  Updated: $DROPIN_FILE"

# Step 3: Enable and start the secrets service
echo "[3/4] Enabling codeshield-secrets.service ..."
systemctl daemon-reload
systemctl enable codeshield-secrets.service
systemctl start codeshield-secrets.service

# Verify decryption worked
if [ -f /run/openclaw-codeshield/secrets.env ]; then
    DECRYPTED_KEYS=$(grep -c '=' /run/openclaw-codeshield/secrets.env 2>/dev/null || echo 0)
    echo "  Secrets decrypted to tmpfs ($DECRYPTED_KEYS keys loaded)"
else
    echo "  ERROR: decryption failed!" >&2
    echo "  Restoring plaintext fallback ..."
    # Emergency: re-decrypt to plaintext so service isn't broken
    systemd-creds decrypt --name=secrets.env "$ENC_FILE" "$PLAIN_FILE"
    chmod 0600 "$PLAIN_FILE"
    # Revert drop-in
    cat > "$DROPIN_FILE" << 'REVERT_EOF'
[Service]
EnvironmentFile=-/etc/openclaw-codeshield/codeshield.env
EnvironmentFile=-/etc/openclaw-codeshield/secrets.env
REVERT_EOF
    systemctl daemon-reload
    exit 1
fi

# Step 4: Restart openclaw to pick up the new EnvironmentFile path
echo "[4/4] Restarting openclaw.service ..."
systemctl restart openclaw.service
sleep 2

if systemctl is-active openclaw.service &>/dev/null; then
    echo ""
    echo "╔══════════════════════════════════════════════════╗"
    echo "║  Migration complete!                            ║"
    echo "║                                                 ║"
    echo "║  At rest:  secrets.env.enc (encrypted, 0600)    ║"
    echo "║  Runtime:  /run/secrets.env (tmpfs, RAM only)   ║"
    echo "║  Disk:     NO plaintext secrets                 ║"
    echo "╚══════════════════════════════════════════════════╝"
    echo ""
    echo "Verify:"
    echo "  ls -la $CS_CONF_DIR/secrets.env      # should NOT exist"
    echo "  ls -la $CS_CONF_DIR/secrets.env.enc   # encrypted file"
    echo "  ls -la /run/openclaw-codeshield/      # decrypted (tmpfs)"
    echo "  systemctl status openclaw.service     # should be active"
else
    echo "WARNING: openclaw.service failed to start after migration!" >&2
    echo "Rolling back ..."
    systemd-creds decrypt --name=secrets.env "$ENC_FILE" "$PLAIN_FILE"
    chmod 0600 "$PLAIN_FILE"
    cat > "$DROPIN_FILE" << 'REVERT_EOF'
[Service]
EnvironmentFile=-/etc/openclaw-codeshield/codeshield.env
EnvironmentFile=-/etc/openclaw-codeshield/secrets.env
REVERT_EOF
    systemctl daemon-reload
    systemctl restart openclaw.service
    echo "Rolled back to plaintext secrets.env. Service restored."
    exit 1
fi
