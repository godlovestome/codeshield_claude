#!/usr/bin/env bash
# CODE SHIELD V3 — Re-seal secrets after Guardian migration
# Called by openclaw-guardian after migrating new secrets from an update.
#
# Flow:
#   1. Guardian writes new secrets to a temp file
#   2. This script merges with existing secrets (decrypted from .enc)
#   3. Seals the merged file
#   4. Restarts codeshield-secrets + openclaw
#
# Usage: codeshield-secrets-reseal [--merge /path/to/new-secrets.env]
#        codeshield-secrets-reseal --seal-existing
set -euo pipefail

CS_CONF_DIR="/etc/openclaw-codeshield"
ENC_FILE="$CS_CONF_DIR/secrets.env.enc"
RUN_DIR="/run/openclaw-codeshield"
TEMP_PLAIN=$(mktemp /dev/shm/secrets-reseal.XXXXXX)
trap 'shred -u "$TEMP_PLAIN" 2>/dev/null || rm -f "$TEMP_PLAIN"' EXIT

MODE="merge"
MERGE_FILE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --merge) MERGE_FILE="$2"; shift 2 ;;
        --seal-existing) MODE="seal-existing"; shift ;;
        *) shift ;;
    esac
done

# Step 1: Get current secrets (decrypt existing .enc if available)
if [ -f "$ENC_FILE" ]; then
    systemd-creds decrypt --name=secrets.env "$ENC_FILE" "$TEMP_PLAIN"
elif [ -f "$RUN_DIR/secrets.env" ]; then
    cp "$RUN_DIR/secrets.env" "$TEMP_PLAIN"
elif [ -f "$CS_CONF_DIR/secrets.env" ]; then
    cp "$CS_CONF_DIR/secrets.env" "$TEMP_PLAIN"
else
    touch "$TEMP_PLAIN"
fi

# Step 2: Merge new secrets if provided
if [ "$MODE" = "merge" ] && [ -n "$MERGE_FILE" ] && [ -f "$MERGE_FILE" ]; then
    # Read new secrets and update/add to existing
    while IFS= read -r line; do
        line=$(echo "$line" | xargs)
        [[ -z "$line" || "$line" == \#* ]] && continue
        KEY="${line%%=*}"
        VALUE="${line#*=}"
        if grep -q "^${KEY}=" "$TEMP_PLAIN" 2>/dev/null; then
            sed -i "s|^${KEY}=.*|${KEY}=${VALUE}|" "$TEMP_PLAIN"
        else
            echo "${KEY}=${VALUE}" >> "$TEMP_PLAIN"
        fi
    done < "$MERGE_FILE"
    # Clean up merge source
    shred -u "$MERGE_FILE" 2>/dev/null || rm -f "$MERGE_FILE"
    echo "Merged new secrets from $MERGE_FILE"
fi

# Step 3: Re-encrypt
chmod 0600 "$TEMP_PLAIN"
codeshield-secrets-seal --from "$TEMP_PLAIN"

# Step 4: Restart secret service → openclaw picks up new secrets
systemctl restart codeshield-secrets.service
echo "Secrets re-sealed and services restarted."
