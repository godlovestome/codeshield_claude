#!/usr/bin/env bash
# CODE SHIELD V3 — Encrypt secrets.env using systemd-creds (host key)
# Usage: codeshield-secrets-seal [--from /path/to/plaintext.env]
#
# Encrypts the plaintext secrets file into secrets.env.enc and removes
# the plaintext from disk. The encrypted file can only be decrypted on
# this host (bound to /var/lib/systemd/credential.secret).
set -euo pipefail

CS_CONF_DIR="/etc/openclaw-codeshield"
ENC_FILE="$CS_CONF_DIR/secrets.env.enc"
PLAIN_FILE="$CS_CONF_DIR/secrets.env"

# Allow overriding source path (used by Guardian after migrating new secrets)
while [[ $# -gt 0 ]]; do
    case "$1" in
        --from) PLAIN_FILE="$2"; shift 2 ;;
        *) shift ;;
    esac
done

if [ ! -f "$PLAIN_FILE" ]; then
    echo "ERROR: plaintext secrets file not found: $PLAIN_FILE" >&2
    exit 1
fi

# Validate the file has content
if [ ! -s "$PLAIN_FILE" ]; then
    echo "ERROR: secrets file is empty: $PLAIN_FILE" >&2
    exit 1
fi

# Encrypt using systemd-creds with the host key
# --name=secrets.env ties the credential to this specific name
systemd-creds encrypt \
    --name=secrets.env \
    --not-after=+90d \
    "$PLAIN_FILE" \
    "$ENC_FILE"

chmod 0600 "$ENC_FILE"
chown root:root "$ENC_FILE"

# Securely wipe the plaintext file
if command -v shred &>/dev/null; then
    shred -u "$PLAIN_FILE"
else
    # Overwrite then remove
    dd if=/dev/urandom of="$PLAIN_FILE" bs=$(stat -c%s "$PLAIN_FILE") count=1 conv=notrunc 2>/dev/null || true
    rm -f "$PLAIN_FILE"
fi

echo "Sealed: $ENC_FILE (plaintext removed)"
echo "Credential valid for 90 days. Re-seal periodically."
