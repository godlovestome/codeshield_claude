#!/usr/bin/env bash
# CODE SHIELD V3 — Decrypt secrets.env.enc to tmpfs for service consumption
# Called by codeshield-secrets.service (ExecStart)
#
# Decrypts the systemd-creds encrypted file to /run/openclaw-codeshield/
# which is a tmpfs-backed RuntimeDirectory — never touches disk.
#
# V3.1.0: Also exports a restricted subset (QDRANT_API_KEY only) to
# /run/openclaw-memory/secrets.env for Jarvis Memory cron jobs running
# as the openclaw user. This avoids storing the key in plaintext
# in ~/.memory_env while keeping it accessible to cron scripts.
set -euo pipefail

CS_CONF_DIR="/etc/openclaw-codeshield"
ENC_FILE="$CS_CONF_DIR/secrets.env.enc"
RUN_DIR="/run/openclaw-codeshield"
OUT_FILE="$RUN_DIR/secrets.env"

# Export QDRANT_API_KEY to a restricted path readable by openclaw group.
# Called from both the main path and the plaintext fallback path.
export_memory_secrets() {
    local source_file="$1"
    local MEMORY_RUN_DIR="/run/openclaw-memory"
    mkdir -p "$MEMORY_RUN_DIR"
    grep '^QDRANT_API_KEY=' "$source_file" > "$MEMORY_RUN_DIR/secrets.env" 2>/dev/null || true
    chown root:openclaw "$MEMORY_RUN_DIR" "$MEMORY_RUN_DIR/secrets.env"
    chmod 750 "$MEMORY_RUN_DIR"
    chmod 640 "$MEMORY_RUN_DIR/secrets.env"
    echo "Exported memory secrets to $MEMORY_RUN_DIR/secrets.env (openclaw-readable)"
}

# Fallback: if encrypted file doesn't exist but plaintext does,
# this allows a grace period during initial migration
if [ ! -f "$ENC_FILE" ]; then
    if [ -f "$CS_CONF_DIR/secrets.env" ]; then
        echo "WARN: encrypted secrets not found, falling back to plaintext" >&2
        echo "WARN: run 'codeshield-secrets-seal' to encrypt" >&2
        mkdir -p "$RUN_DIR"
        cp "$CS_CONF_DIR/secrets.env" "$OUT_FILE"
        chmod 0600 "$OUT_FILE"
        export_memory_secrets "$OUT_FILE"
        exit 0
    fi
    echo "ERROR: no secrets file found (neither .enc nor plaintext)" >&2
    exit 1
fi

# Ensure output directory exists (RuntimeDirectory should create it,
# but be defensive)
mkdir -p "$RUN_DIR"

# Decrypt using systemd-creds
systemd-creds decrypt \
    --name=secrets.env \
    "$ENC_FILE" \
    "$OUT_FILE"

chmod 0600 "$OUT_FILE"
chown root:root "$OUT_FILE"

echo "Unsealed secrets to $OUT_FILE (tmpfs)"
export_memory_secrets "$OUT_FILE"
