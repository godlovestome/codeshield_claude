#!/usr/bin/env bash
# CODE SHIELD V3 — Decrypt secrets.env.enc to tmpfs for service consumption
# Called by codeshield-secrets.service (ExecStart)
#
# Decrypts the systemd-creds encrypted file to /run/openclaw-codeshield/
# which is a tmpfs-backed RuntimeDirectory — never touches disk.
set -euo pipefail

CS_CONF_DIR="/etc/openclaw-codeshield"
ENC_FILE="$CS_CONF_DIR/secrets.env.enc"
RUN_DIR="/run/openclaw-codeshield"
OUT_FILE="$RUN_DIR/secrets.env"

# Fallback: if encrypted file doesn't exist but plaintext does,
# this allows a grace period during initial migration
if [ ! -f "$ENC_FILE" ]; then
    if [ -f "$CS_CONF_DIR/secrets.env" ]; then
        echo "WARN: encrypted secrets not found, falling back to plaintext" >&2
        echo "WARN: run 'codeshield-secrets-seal' to encrypt" >&2
        mkdir -p "$RUN_DIR"
        cp "$CS_CONF_DIR/secrets.env" "$OUT_FILE"
        chmod 0600 "$OUT_FILE"
        exit 0
    fi
    echo "ERROR: no secrets file found (neither .enc nor plaintext)" >&2
    exit 1
fi

# Ensure output directory exists (RuntimeDirectory should create it,
# but be defensive)
mkdir -p "$RUN_DIR"

# Decrypt using systemd-creds
systemd-creds decrypt \
    --name=secrets.env \
    "$ENC_FILE" \
    "$OUT_FILE"

chmod 0600 "$OUT_FILE"
chown root:root "$OUT_FILE"

echo "Unsealed secrets to $OUT_FILE (tmpfs)"
