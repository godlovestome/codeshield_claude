#!/usr/bin/env bash
# CODE SHIELD V3 -- Guardian: Re-apply protection after OpenClaw update
# Called by codeshield-guardian.service when openclaw package.json changes.
set -euo pipefail

###############################################################################
# Constants
###############################################################################
readonly CS_CONF_DIR="/etc/openclaw-codeshield"
readonly CS_DATA_DIR="/var/lib/openclaw-codeshield"
readonly CS_LOG_DIR="/var/log/openclaw-codeshield"
readonly CS_SBIN_DIR="/usr/local/sbin"
readonly SECRETS_FILE="$CS_CONF_DIR/secrets.env"
readonly OPENCLAW_HOME="/home/openclaw"
readonly OPENCLAW_SVC_HOME="/var/lib/openclaw-svc"
readonly OPENCLAW_JSON="$OPENCLAW_HOME/.openclaw/openclaw.json"
readonly DROPIN_DIR="/etc/systemd/system/openclaw.service.d"
readonly DROPIN_FILE="$DROPIN_DIR/codeshield.conf"

mkdir -p "$CS_LOG_DIR"
exec >> "$CS_LOG_DIR/guardian.log" 2>&1

log() { echo "[$(date -Iseconds)] GUARDIAN: $*"; }

read_env_file_value() {
    local env_file="$1" key="$2"
    [ -f "$env_file" ] || return 0
    grep -E "^${key}=" "$env_file" 2>/dev/null | head -1 | cut -d'=' -f2- || true
}

normalize_workspace_config() {
    local json_file="$1" workspace_path="$2" owner="$3"
    [ -f "$json_file" ] || return 0
    python3 - "$json_file" "$workspace_path" <<'PYEOF'
import json, sys
from pathlib import Path

json_file = Path(sys.argv[1])
workspace_path = sys.argv[2]
cfg = json.loads(json_file.read_text(encoding='utf-8'))
defaults = cfg.setdefault('agents', {}).setdefault('defaults', {})
defaults['workspace'] = workspace_path
json_file.write_text(json.dumps(cfg, ensure_ascii=False, indent=2) + "\n", encoding='utf-8')
PYEOF
    chown "${owner}:${owner}" "$json_file"
    chmod 0600 "$json_file"
}

ensure_dropin_line() {
    local needle="$1" insert_after="$2"
    if ! grep -q "$needle" "$DROPIN_FILE" 2>/dev/null; then
        python3 - "$DROPIN_FILE" "$needle" "$insert_after" <<'PYEOF'
from pathlib import Path
import sys

path = Path(sys.argv[1])
needle = sys.argv[2]
insert_after = sys.argv[3]
lines = path.read_text(encoding='utf-8').splitlines()
result = []
inserted = False
for line in lines:
    result.append(line)
    if (not inserted) and line == insert_after:
        result.append(needle)
        inserted = True
if not inserted:
    result.append(needle)
path.write_text("\n".join(result) + "\n", encoding='utf-8')
PYEOF
        log "  Added missing drop-in line: ${needle}"
    fi
}

sync_soul_file() {
    local soul_file="$1" template_file="$2" canary="$3" owner="$4"
    python3 - "$soul_file" "$template_file" "$canary" <<'PYEOF'
from pathlib import Path
import sys

soul_path = Path(sys.argv[1])
template_path = Path(sys.argv[2])
canary = sys.argv[3]

managed = template_path.read_text(encoding='utf-8').replace('{{CANARY}}', canary).strip() + '\n'
text = soul_path.read_text(encoding='utf-8') if soul_path.exists() else ''

begin = '<!-- CODESHIELD-SOUL-BEGIN -->'
end = '<!-- CODESHIELD-SOUL-END -->'
legacy_heading = '## Prompt Injection Resistance (CODE SHIELD V3)'

if begin in text and end in text:
    start = text.index(begin)
    finish = text.index(end, start) + len(end)
    text = text[:start].rstrip() + text[finish:].rstrip()
elif legacy_heading in text:
    text = text[:text.index(legacy_heading)].rstrip()
else:
    text = text.rstrip()

if text:
    text += '\n\n'
text += managed
soul_path.parent.mkdir(parents=True, exist_ok=True)
soul_path.write_text(text, encoding='utf-8')
PYEOF
    chown "${owner}:${owner}" "$soul_file"
    chmod 0644 "$soul_file"
}

###############################################################################
# Load secrets for Telegram notification
###############################################################################
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# Prefer tmpfs (decrypted) secrets, fall back to plaintext on disk
SECRETS_RUNTIME="/run/openclaw-codeshield/secrets.env"
if [ -f "$SECRETS_RUNTIME" ]; then
    TELEGRAM_BOT_TOKEN="$(read_env_file_value "$SECRETS_RUNTIME" TELEGRAM_BOT_TOKEN)"
    TELEGRAM_CHAT_ID="$(read_env_file_value "$SECRETS_RUNTIME" TELEGRAM_CHAT_ID)"
elif [ -f "$SECRETS_FILE" ]; then
    TELEGRAM_BOT_TOKEN="$(read_env_file_value "$SECRETS_FILE" TELEGRAM_BOT_TOKEN)"
    TELEGRAM_CHAT_ID="$(read_env_file_value "$SECRETS_FILE" TELEGRAM_CHAT_ID)"
fi

send_telegram() {
    local msg="$1"
    if [ -n "$TELEGRAM_BOT_TOKEN" ] && [ -n "$TELEGRAM_CHAT_ID" ]; then
        curl -sf -X POST \
            "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
            -d "chat_id=${TELEGRAM_CHAT_ID}" \
            -d "text=${msg}" \
            -d "parse_mode=HTML" \
            --max-time 10 &>/dev/null || true
    fi
}

log "========== Guardian triggered =========="
log "Detected OpenClaw update event."

###############################################################################
# Step 1: Migrate inline secrets from openclaw.json
###############################################################################
log "Step 1: Checking for inline secrets in openclaw.json ..."

if [ -f "$OPENCLAW_JSON" ]; then
    declare -A KEY_MAP=(
        ["telegramBotToken"]="TELEGRAM_BOT_TOKEN"
        ["braveApiKey"]="BRAVE_API_KEY"
        ["openaiApiKey"]="OPENAI_API_KEY"
        ["gatewayToken"]="OPENCLAW_GATEWAY_TOKEN"
        ["qdrantApiKey"]="QDRANT_API_KEY"
    )

    MIGRATED=0
    for jkey in "${!KEY_MAP[@]}"; do
        ekey="${KEY_MAP[$jkey]}"
        jval=$(jq -r ".$jkey // empty" "$OPENCLAW_JSON" 2>/dev/null || true)
        if [ -n "$jval" ] && [ "$jval" != "null" ]; then
            log "  Migrating $jkey -> $ekey"
            if grep -q "^${ekey}=" "$SECRETS_FILE" 2>/dev/null; then
                sed -i "s|^${ekey}=.*|${ekey}=${jval}|" "$SECRETS_FILE"
            else
                echo "${ekey}=${jval}" >> "$SECRETS_FILE"
            fi
            # Blank out in openclaw.json
            tmp=$(jq ".$jkey = \"\"" "$OPENCLAW_JSON")
            echo "$tmp" > "$OPENCLAW_JSON"
            MIGRATED=$((MIGRATED + 1))
        fi
    done

    if [ "$MIGRATED" -gt 0 ]; then
        chmod 0600 "$SECRETS_FILE"
        chown root:root "$SECRETS_FILE"
        log "  Migrated $MIGRATED secret(s)."
    else
        log "  No inline secrets found."
    fi
else
    log "  openclaw.json not found. Skipping."
fi

###############################################################################
# Step 1b: Ensure proxy vars exist in secrets (V3.0.5 fix)
#          openclaw-svc is network-isolated; needs proxy for outbound
###############################################################################
log "Step 1b: Ensuring proxy environment variables ..."

# Find the active secrets file
ACTIVE_SECRETS=""
if [ -f "/run/openclaw-codeshield/secrets.env" ]; then
    ACTIVE_SECRETS="/run/openclaw-codeshield/secrets.env"
elif [ -f "$SECRETS_FILE" ]; then
    ACTIVE_SECRETS="$SECRETS_FILE"
fi

if [ -n "$ACTIVE_SECRETS" ]; then
    # V3.0.9: Include NODE_USE_ENV_PROXY (required for Node.js 22+ undici to
    # respect proxy env vars) and NO_PROXY (prevent loopback services like
    # Qdrant from being routed through Squid).
    # V3.0.10: Add NODE_OPTIONS with undici ProxyAgent preload.  Even with
    # NODE_USE_ENV_PROXY=1, web_fetch may bypass the global dispatcher.
    # The preload forces ALL fetch() calls through ProxyAgent.
    readonly CS_LIB_DIR="/usr/local/lib/openclaw-codeshield"
    declare -A PROXY_VARS=(
        [HTTPS_PROXY]="http://127.0.0.1:3128"
        [HTTP_PROXY]="http://127.0.0.1:3128"
        [https_proxy]="http://127.0.0.1:3128"
        [http_proxy]="http://127.0.0.1:3128"
        [NO_PROXY]="127.0.0.1,localhost"
        [no_proxy]="127.0.0.1,localhost"
        [NODE_USE_ENV_PROXY]="1"
        [NODE_OPTIONS]="--import ${CS_LIB_DIR}/proxy-preload.mjs"
    )
    PROXY_ADDED=0
    for pvar in "${!PROXY_VARS[@]}"; do
        if ! grep -qE "^${pvar}=" "$ACTIVE_SECRETS" 2>/dev/null; then
            echo "${pvar}=${PROXY_VARS[$pvar]}" >> "$ACTIVE_SECRETS"
            PROXY_ADDED=1
        fi
    done
    if [ "$PROXY_ADDED" -eq 1 ]; then
        log "  Added missing proxy vars to secrets."
        # Re-encrypt if encrypted secrets exist
        if [ -f "$CS_CONF_DIR/secrets.env.enc" ] && [ "$ACTIVE_SECRETS" = "/run/openclaw-codeshield/secrets.env" ]; then
            # Copy tmpfs secrets back for re-sealing
            cp "$ACTIVE_SECRETS" "$SECRETS_FILE"
            chmod 0600 "$SECRETS_FILE"
            chown root:root "$SECRETS_FILE"
            if [ -x "$CS_SBIN_DIR/codeshield-secrets-seal" ]; then
                "$CS_SBIN_DIR/codeshield-secrets-seal" --from "$SECRETS_FILE"
                # Re-unseal to tmpfs
                "$CS_SBIN_DIR/codeshield-secrets-unseal" 2>/dev/null || true
            fi
            log "  Re-encrypted secrets with proxy vars."
        fi
    else
        log "  Proxy vars already present."
    fi
fi

###############################################################################
# Step 2: Ensure systemd drop-in exists
###############################################################################
log "Step 2: Verifying systemd drop-in ..."

mkdir -p "$DROPIN_DIR"
if [ ! -f "$DROPIN_FILE" ]; then
    log "  Drop-in missing. Recreating."
    cat > "$DROPIN_FILE" << 'EOF'
# CODE SHIELD V3 -- systemd drop-in (regenerated by guardian)
[Unit]
After=codeshield-secrets.service
Requires=codeshield-secrets.service

[Service]
User=openclaw-svc
Group=openclaw-svc
EnvironmentFile=/run/openclaw-codeshield/secrets.env
Environment=HOME=/var/lib/openclaw-svc
Environment=XDG_CONFIG_HOME=/var/lib/openclaw-svc/.config
WorkingDirectory=/var/lib/openclaw-svc
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=yes
ReadWritePaths=/var/lib/openclaw-svc
EOF
    log "  Drop-in recreated."
else
    # V3.0.5: Fix EnvironmentFile path if still pointing to /etc/ instead of /run/
    if grep -q 'EnvironmentFile=/etc/openclaw-codeshield/secrets.env' "$DROPIN_FILE" 2>/dev/null; then
        log "  Drop-in has stale EnvironmentFile path. Updating to /run/ ..."
        sed -i 's|EnvironmentFile=/etc/openclaw-codeshield/secrets.env|EnvironmentFile=/run/openclaw-codeshield/secrets.env|' "$DROPIN_FILE"
        # Also ensure [Unit] section with service dependency exists
        if ! grep -q 'codeshield-secrets.service' "$DROPIN_FILE" 2>/dev/null; then
            sed -i '/^\[Service\]/i [Unit]\nAfter=codeshield-secrets.service\nRequires=codeshield-secrets.service\n' "$DROPIN_FILE"
        fi
        log "  Drop-in updated."
    else
        log "  Drop-in exists and path is correct."
    fi
    ensure_dropin_line 'Environment=HOME=/var/lib/openclaw-svc' 'EnvironmentFile=/run/openclaw-codeshield/secrets.env'
    ensure_dropin_line 'Environment=XDG_CONFIG_HOME=/var/lib/openclaw-svc/.config' 'Environment=HOME=/var/lib/openclaw-svc'
    ensure_dropin_line 'WorkingDirectory=/var/lib/openclaw-svc' 'Environment=XDG_CONFIG_HOME=/var/lib/openclaw-svc/.config'
fi

###############################################################################
# Step 3: Sync openclaw data
###############################################################################
log "Step 3: Syncing openclaw data ..."

mkdir -p "$OPENCLAW_SVC_HOME/.openclaw"
mkdir -p "$OPENCLAW_SVC_HOME/.openclaw/workspace"
if [ -d "$OPENCLAW_HOME/.openclaw" ]; then
    rsync -a --update "$OPENCLAW_HOME/.openclaw/" "$OPENCLAW_SVC_HOME/.openclaw/" 2>/dev/null || \
        cp -a "$OPENCLAW_HOME/.openclaw/"* "$OPENCLAW_SVC_HOME/.openclaw/" 2>/dev/null || true
    if [ -f "$OPENCLAW_HOME/.claude.json" ]; then
        install -m 0600 -o openclaw-svc -g openclaw-svc "$OPENCLAW_HOME/.claude.json" "$OPENCLAW_SVC_HOME/.claude.json"
    fi
    normalize_workspace_config \
        "$OPENCLAW_HOME/.openclaw/openclaw.json" \
        "$OPENCLAW_HOME/.openclaw/workspace" \
        "openclaw"
    normalize_workspace_config \
        "$OPENCLAW_SVC_HOME/.openclaw/openclaw.json" \
        "$OPENCLAW_SVC_HOME/.openclaw/workspace" \
        "openclaw-svc"
    chown -R openclaw-svc:openclaw-svc "$OPENCLAW_SVC_HOME/.openclaw"
    log "  Data synced."
fi

###############################################################################
# Step 4: Ensure SOUL.md has canary + injection resistance
###############################################################################
log "Step 4: Checking SOUL.md canary ..."

CANARY=""
if [ -f "$CS_DATA_DIR/soul-canary.txt" ]; then
    CANARY=$(cat "$CS_DATA_DIR/soul-canary.txt")
fi

for soul_dir in "$OPENCLAW_HOME/.openclaw" "$OPENCLAW_SVC_HOME/.openclaw"; do
    soul_file="$soul_dir/SOUL.md"
    owner="openclaw"
    [ "$soul_dir" = "$OPENCLAW_SVC_HOME/.openclaw" ] && owner="openclaw-svc"
    INJECTION_TEMPLATE="/usr/local/lib/openclaw-codeshield/soul-injection.md"
    if [ -f "$INJECTION_TEMPLATE" ] && [ -n "$CANARY" ]; then
        sync_soul_file "$soul_file" "$INJECTION_TEMPLATE" "$CANARY" "$owner"
        log "  SOUL.md protection refreshed at $soul_file."
    fi
done

###############################################################################
# Step 5: Ensure skills-policy.json exists
###############################################################################
log "Step 5: Checking skills policy ..."

POLICY_SRC="/usr/local/lib/openclaw-codeshield/skills-policy.json"
for target_dir in "$OPENCLAW_HOME/.openclaw" "$OPENCLAW_SVC_HOME/.openclaw"; do
    if [ ! -f "$target_dir/skills-policy.json" ] && [ -f "$POLICY_SRC" ]; then
        cp "$POLICY_SRC" "$target_dir/skills-policy.json"
        log "  Restored skills-policy.json at $target_dir"
    fi
done

###############################################################################
# Step 6: Regenerate skills baseline if new skills appeared
###############################################################################
log "Step 6: Updating skills baseline ..."

BASELINE_FILE="$CS_DATA_DIR/skills-baseline.json"
SKILLS_DIR=""
for candidate in "$OPENCLAW_HOME/.openclaw/skills" "$OPENCLAW_SVC_HOME/.openclaw/skills"; do
    if [ -d "$candidate" ]; then
        SKILLS_DIR="$candidate"
        break
    fi
done

if [ -n "$SKILLS_DIR" ]; then
    BASELINE='{"skills":['
    FIRST=1
    while IFS= read -r -d '' skill_file; do
        HASH=$(sha256sum "$skill_file" | awk '{print $1}')
        NAME=$(basename "$skill_file")
        [ "$FIRST" -eq 0 ] && BASELINE+=","
        BASELINE+="{\"name\":\"$NAME\",\"sha256\":\"$HASH\"}"
        FIRST=0
    done < <(find "$SKILLS_DIR" -type f -print0 2>/dev/null)
    BASELINE+="],"
    BASELINE+="\"generated\":\"$(date -Iseconds)\"}"
    echo "$BASELINE" | jq . > "$BASELINE_FILE" 2>/dev/null || echo "$BASELINE" > "$BASELINE_FILE"
    log "  Skills baseline updated."
fi

###############################################################################
# Step 7: Reload systemd and restart openclaw
###############################################################################
log "Step 7: Restarting openclaw ..."

systemctl daemon-reload
systemctl restart openclaw.service 2>/dev/null || true

# Wait a moment and check health
sleep 3
if systemctl is-active openclaw.service &>/dev/null; then
    log "  openclaw.service is active."
else
    log "  WARNING: openclaw.service is not active after restart!"
    send_telegram "CODE SHIELD WARNING: OpenClaw service failed to restart after update!"
fi

###############################################################################
# Step 8: Verify Telegram and send notification
###############################################################################
log "Step 8: Sending notification ..."

if [ -n "$TELEGRAM_BOT_TOKEN" ] && [ -n "$TELEGRAM_CHAT_ID" ]; then
    # Quick connectivity test
    HTTP_CODE=$(curl -sf -o /dev/null -w '%{http_code}' \
        "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/getMe" \
        --max-time 10 2>/dev/null || echo "000")

    if [ "$HTTP_CODE" = "200" ]; then
        send_telegram "CODE SHIELD: OpenClaw has been updated. Protection re-applied successfully. $(date '+%Y-%m-%d %H:%M:%S')"
        log "  Telegram notification sent."
    else
        log "  Telegram connectivity check failed (HTTP $HTTP_CODE)."
    fi
else
    log "  No Telegram credentials. Skipping notification."
fi

log "========== Guardian complete =========="

exit 0
